{
  "id": "logger",
  "name": "Logger",
  "category": "default",
  "description": "Log messages",
  "input": {
    "type": "object",
    "properties": {
      "message": {
        "type": "string",
        "description": "Message to log"
      },
      "level": {
        "type": "string",
        "enum": ["info", "warn", "error"],
        "default": "info"
      }
    },
    "required": ["message"]
  },
  "output": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "logged": { "type": "string" }
    }
  }
}
