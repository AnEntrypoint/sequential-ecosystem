{
  "name": "sequential-ecosystem",
  "version": "1.8.0",
  "description": "Infinite-length task execution with automatic suspend/resume and flow/machine runners",
  "type": "module",
  "scripts": {
    "start": "PORT=8003 node scripts/gxe-dispatch.js desktop-server",
    "server": "PORT=8003 node scripts/gxe-dispatch.js desktop-server",
    "mcp": "node packages/execution-mcp-server/src/stdio-server.js",
    "mcp:status": "PORT=8003 node packages/execution-mcp-server/src/cli.js status",
    "mcp:start": "PORT=8003 node packages/execution-mcp-server/src/cli.js start",
    "mcp:stop": "PORT=8003 node packages/execution-mcp-server/src/cli.js stop",
    "mcp:restart": "PORT=8003 node packages/execution-mcp-server/src/cli.js restart",
    "cli": "node cli.js",
    "init": "node cli.js init",
    "create": "node cli.js create-task",
    "run": "node cli.js run",
    "list": "node cli.js list",
    "sync": "node cli.js sync-tasks",
    "zellous": "node packages/zellous/server.js",
    "dev": "nodemon --delay 1000 --ignore '**/runs/**' packages/desktop-server/src/server.js",
    "gxe:task": "node scripts/gxe-dispatch.js webhook:task",
    "gxe:flow": "node scripts/gxe-dispatch.js webhook:flow",
    "gxe:tool": "node scripts/gxe-dispatch.js webhook:tool",
    "lint": "eslint packages --ext .js --ignore-path .gitignore || true",
    "lint:fix": "eslint packages --ext .js --ignore-path .gitignore --fix || true",
    "build": "find packages -name package.json -exec dirname {} \\; | xargs -I {} sh -c 'cd {} && npm run build 2>/dev/null || true'"
  },
  "keywords": [
    "sequential",
    "task-execution",
    "xstate",
    "sequential-machine",
    "sequential-flow",
    "suspend-resume",
    "deno",
    "bun",
    "node",
    "infinite-tasks",
    "workflow",
    "state-machine",
    "filesystem-layers",
    "checkpoints"
  ],
  "author": "lanmower",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/sequential-ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/AnEntrypoint/sequential-ecosystem/issues"
  },
  "homepage": "https://github.com/AnEntrypoint/sequential-ecosystem#readme",
  "bin": {
    "sequential-ecosystem": "./scripts/gxe-dispatch.js",
    "seq": "./cli.js",
    "task": "./scripts/task.js",
    "flow": "./scripts/flow.js",
    "tool": "./scripts/tool.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "cli.js",
    "scripts/gxe-dispatch.js",
    "scripts/gxe-dispatch/",
    "scripts/task.js",
    "scripts/task",
    "scripts/flow.js",
    "scripts/flow",
    "scripts/tool.js",
    "scripts/tool",
    "packages/",
    "flows/",
    "tools/",
    "CLAUDE.md",
    "CHANGELOG.md",
    "README.md",
    "GXE_DISPATCH.md"
  ],
  "dependencies": {
    "body-parser": "^1.20.2",
    "chokidar": "^5.0.0",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "eventemitter3": "^5.0.1",
    "express": "^4.18.2",
    "nanoid": "^5.1.6",
    "p-debounce": "^5.1.0",
    "p-memoize": "^8.0.0",
    "p-queue": "^9.0.1",
    "p-retry": "^7.1.1",
    "p-throttle": "^8.1.0",
    "p-timeout": "^7.0.1",
    "ws": "^8.14.2",
    "xstate": "^5.25.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
