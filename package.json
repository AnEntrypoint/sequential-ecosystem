{
  "name": "sequential-ecosystem",
  "version": "1.7.0",
  "description": "Infinite-length task execution with automatic suspend/resume and flow/machine runners",
  "type": "module",
  "scripts": {
    "start": "node cli.js",
    "cli": "node cli.js",
    "init": "node cli.js init",
    "create": "node cli.js create-task",
    "run": "node cli.js run",
    "list": "node cli.js list",
    "sync": "node cli.js sync-tasks",

    "zellous": "node packages/zellous/server.js",
    "dev": "node -e \"const{spawn}=require('child_process');const z=spawn('node',['packages/zellous/server.js'],{stdio:'inherit'});const o=spawn('node',['packages/osjs-webdesktop/src/server/index.js'],{stdio:'inherit'});process.on('SIGINT',()=>{z.kill();o.kill();process.exit()});\"",
    "test": "find packages -name package.json -exec dirname {} \\; | xargs -I {} sh -c 'cd {} && npm test 2>/dev/null || true'",
    "lint": "find packages -name package.json -exec dirname {} \\; | xargs -I {} sh -c 'cd {} && npm run lint 2>/dev/null || true'",
    "build": "find packages -name package.json -exec dirname {} \\; | xargs -I {} sh -c 'cd {} && npm run build 2>/dev/null || true'"
  },
  "keywords": [
    "sequential",
    "task-execution",
    "xstate",
    "sequential-machine",
    "sequential-flow",
    "suspend-resume",
    "deno",
    "bun",
    "node",
    "infinite-tasks",
    "workflow",
    "state-machine",
    "filesystem-layers",
    "checkpoints"
  ],
  "author": "lanmower",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/sequential-ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/AnEntrypoint/sequential-ecosystem/issues"
  },
  "homepage": "https://github.com/AnEntrypoint/sequential-ecosystem#readme",
  "bin": {
    "sequential-ecosystem": "./cli.js",
    "seq": "./cli.js"
  },
  "files": [
    "cli.js",
    "tools",
    "CLAUDE.md",
    "CHANGELOG.md",
    "README.md"
  ],
  "dependencies": {
    "commander": "^11.0.0",
    "sequential-adaptor": "^1.0.7",
    "sequential-flow": "^1.0.1",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
