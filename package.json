{
  "name": "sequential-ecosystem",
  "version": "1.8.0",
  "description": "Infinite-length task execution with automatic suspend/resume and flow/machine runners",
  "type": "module",
  "scripts": {
    "start": "node cli.js",
    "cli": "node cli.js",
    "init": "node cli.js init",
    "create": "node cli.js create-task",
    "run": "node cli.js run",
    "list": "node cli.js list",
    "sync": "node cli.js sync-tasks",

    "zellous": "node packages/zellous/server.js",
    "dev": "node packages/desktop-server/src/server.js",
    "test": "node scripts/test-all.js",
    "test:watch": "find packages -name package.json -exec dirname {} \\; | xargs -I {} sh -c 'cd {} && npm run test:watch 2>/dev/null || true'",
    "test:coverage": "c8 node scripts/test-all.js",
    "lint": "eslint packages --ext .js --ignore-path .gitignore || true",
    "lint:fix": "eslint packages --ext .js --ignore-path .gitignore --fix || true",
    "build": "find packages -name package.json -exec dirname {} \\; | xargs -I {} sh -c 'cd {} && npm run build 2>/dev/null || true'"
  },
  "keywords": [
    "sequential",
    "task-execution",
    "xstate",
    "sequential-machine",
    "sequential-flow",
    "suspend-resume",
    "deno",
    "bun",
    "node",
    "infinite-tasks",
    "workflow",
    "state-machine",
    "filesystem-layers",
    "checkpoints"
  ],
  "author": "lanmower",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/sequential-ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/AnEntrypoint/sequential-ecosystem/issues"
  },
  "homepage": "https://github.com/AnEntrypoint/sequential-ecosystem#readme",
  "bin": {
    "sequential-ecosystem": "./cli.js",
    "seq": "./cli.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "cli.js",
    "CLAUDE.md",
    "CHANGELOG.md",
    "README.md"
  ],
  "dependencies": {
    "@sequentialos/cli-commands": "file:./packages/@sequential/cli-commands",
    "@sequentialos/timestamp-utilities": "file:./packages/@sequential/timestamp-utilities",
    "@sequentialos/error-handling": "file:./packages/@sequential/error-handling",
    "@sequentialos/server-utilities": "file:./packages/@sequential/server-utilities",
    "@sequentialos/file-operations": "file:./packages/@sequential/file-operations",
    "@sequentialos/param-validation": "file:./packages/@sequential/param-validation",
    "@sequentialos/response-formatting": "file:./packages/@sequential/response-formatting",
    "@sequentialos/request-validator": "file:./packages/@sequential/request-validator",
    "@sequentialos/dependency-middleware": "file:./packages/@sequential/dependency-middleware",
    "@sequentialos/route-helpers": "file:./packages/@sequential/route-helpers",
    "@sequentialos/crud-router": "file:./packages/@sequential/crud-router",
    "@sequentialos/async-patterns": "file:./packages/@sequential/async-patterns",
    "@sequentialos/core": "file:./packages/@sequential/core",
    "@sequentialos/sequential-logging": "file:./packages/@sequential/sequential-logging",
    "commander": "^11.0.0",
    "@sequentialos/sequential-adaptor": "file:./packages/@sequential/sequential-adaptor",
    "@sequentialos/sequential-flow": "file:./packages/@sequential/sequential-flow",
    "@sequentialos/persistent-state": "file:./packages/@sequential/persistent-state",
    "@sequentialos/realtime-sync": "file:./packages/@sequential/realtime-sync",
    "@sequentialos/tool-registry": "file:./packages/@sequential/tool-registry",
    "@sequentialos/dynamic-components": "file:./packages/@sequential/dynamic-components",
    "@sequentialos/observability-utils": "file:./packages/@sequential/observability-utils",
    "@sequentialos/handler-wrappers": "file:./packages/@sequential/handler-wrappers",
    "@sequentialos/config-management": "file:./packages/@sequential/config-management",
    "@sequentialos/error-utilities": "file:./packages/@sequential/error-utilities",
    "@sequentialos/execution-context": "file:./packages/@sequential/execution-context",
    "@sequentialos/function-introspection": "file:./packages/@sequential/function-introspection",
    "@sequentialos/text-encoding": "file:./packages/@sequential/text-encoding",
    "@sequentialos/rate-limiter": "file:./packages/@sequential/rate-limiter",
    "@sequentialos/validation": "file:./packages/@sequential/validation",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "c8": "^8.0.1",
    "eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
