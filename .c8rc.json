{
  "all": true,
  "include": [
    "packages/*/src/**/*.js",
    "packages/*/lib/**/*.js"
  ],
  "exclude": [
    "**/*.test.js",
    "**/*.spec.js",
    "**/test/**",
    "**/node_modules/**",
    "**/coverage/**",
    "**/dist/**"
  ],
  "reporter": [
    "text",
    "text-summary",
    "lcov",
    "html"
  ],
  "check-coverage": true,
  "lines": 70,
  "functions": 70,
  "branches": 70,
  "statements": 70,
  "per-file": true,
  "report-dir": "./coverage",
  "temp-directory": "./coverage/.nyc_output"
}
