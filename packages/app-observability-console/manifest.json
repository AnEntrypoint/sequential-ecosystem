{
  "id": "app-observability-console",
  "name": "Observability Console",
  "description": "Real-time event stream and system activity monitor",
  "version": "1.0.0",
  "category": "observability",
  "icon": "📡",
  "entry": "dist/dynamic-index.html",
  "features": [
    "Real-time event stream",
    "Filter by type, app, severity",
    "Tool call tracing",
    "State transitions",
    "HTTP requests",
    "Custom events",
    "Search and correlation ID tracking"
  ],
  "permissions": [
    "read:observability",
    "read:realtime",
    "read:traces"
  ],
  "window": {
    "defaultWidth": 1200,
    "defaultHeight": 800,
    "minWidth": 600,
    "minHeight": 400,
    "resizable": true,
    "maximizable": true
  }
}
