{
  "name": "@sequential/unified-validation",
  "version": "1.0.0",
  "description": "Unified validation engine consolidating schema validation, type checking, and error formatting",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./ajv": "./src/ajv-instance.js",
    "./schema": "./src/schema-compiler.js",
    "./field": "./src/field-validators.js",
    "./type": "./src/type-validators.js",
    "./result": "./src/validation-result.js",
    "./error": "./src/error-formatter.js"
  },
  "keywords": [
    "validation",
    "schema",
    "json-schema",
    "type-checking",
    "error-formatting"
  ],
  "dependencies": {
    "ajv": "^8.12.0"
  }
}
