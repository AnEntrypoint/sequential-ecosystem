{
  "name": "@sequential/dynamic-components",
  "version": "1.0.0",
  "description": "V0-style dynamic component system - write and deploy React components with full provider/boundary architecture, no build required",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./core": "./src/core.js",
    "./providers": "./src/providers/index.js",
    "./boundaries": "./src/boundaries/index.js",
    "./hooks": "./src/hooks.js",
    "./interceptors": "./src/interceptors/index.js"
  },
  "scripts": {
    "test": "node --test test/**/*.js"
  },
  "keywords": [
    "react",
    "components",
    "v0",
    "dynamic",
    "jsx",
    "buildless",
    "providers",
    "boundaries",
    "real-time"
  ],
  "dependencies": {
    "@babel/standalone": "^7.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/sequential-ecosystem.git"
  }
}
