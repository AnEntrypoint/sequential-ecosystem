{
  "name": "@sequentialos/desktop-server",
  "version": "1.0.0",
  "description": "Modular server for Sequential Desktop with app registry and plugin system",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test tests/**/*.test.js --watch",
    "test:coverage": "node --test tests/**/*.test.js --coverage"
  },
  "keywords": [
    "sequential",
    "desktop",
    "server",
    "apps"
  ],
  "author": "Sequential Ecosystem",
  "license": "MIT",
  "dependencies": {
    "@sequentialos/core": "*",
    "@sequentialos/core-config": "*",
    "@sequentialos/data-access-layer": "*",
    "@sequentialos/dependency-injection": "*",
    "@sequentialos/task-execution-service": "*",
    "@sequentialos/error-handling": "*",
    "@sequentialos/param-validation": "*",
    "file-operations": "file:../../packages/@sequentialos/file-operations",
    "@sequentialos/persistent-state": "*",
    "@sequentialos/sequential-os-http": "*",
    "@sequentialos/websocket-broadcaster": "*",
    "server-utilities": "file:../../packages/@sequentialos/server-utilities",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "ws": "^8.14.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/sequential-desktop-server"
  }
}
